RUN git clone https://github.com/jtydhr88/ComfyUI-qwenmultiangle /comfyui/custom_nodes/ComfyUI-qwenmultiangle && cd /comfyui/custom_nodes/ComfyUI-qwenmultiangle && (git checkout a6539524a96d21bea6fe0fc01d9b792d2cb1844b 2>/dev/null || (git fetch origin a6539524a96d21bea6fe0fc01d9b792d2cb1844b --depth=1 && git checkout a6539524a96d21bea6fe0fc01d9b792d2cb1844b) || echo "WARN: commit a6539524a96d21bea6fe0fc01d9b792d2cb1844b unreachable in https://github.com/jtydhr88/ComfyUI-qwenmultiangle, falling back to default branch HEAD")

